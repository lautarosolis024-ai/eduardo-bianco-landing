# Environment variables for Eduardo Bianco Landing Page
# Copy this file to .env.local and fill in the values

# Resend API Key (optional — get from https://resend.com)
# When not set, the contact form falls back to WhatsApp
RESEND_API_KEY=re_xxxxxxxx

# Email configuration (optional — used with Resend)
EMAIL_FROM=onboarding@resend.dev
EMAIL_TO=ejuliobianco@gmail.com
